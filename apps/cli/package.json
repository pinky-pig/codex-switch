{
  "name": "@codex-switch/cli",
  "version": "0.1.0",
  "description": "Codex Switch CLI and TUI",
  "type": "module",
  "bin": {
    "codex-switch": "./dist/cli.js",
    "cxs": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "ink": "^6.3.1",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
